# =============================================================================
# Python
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
develop-eggs/
.installed.cfg
lib/
lib64/
.eggs/

# =============================================================================
# Virtual environments
# =============================================================================
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# =============================================================================
# Generated data — never commit sample data to the repo
# Raw files produced by scripts/generate_sample_data.py land here
# =============================================================================
/tmp/
*.csv
*.json
*.parquet
*.avro
*.orc

# =============================================================================
# Spark / Delta Lake local artifacts
# These are created when running PySpark locally outside Databricks
# =============================================================================
derby.log
metastore_db/
spark-warehouse/
checkpoint/
_delta_log/

# =============================================================================
# Test artifacts
# =============================================================================
.pytest_cache/
.coverage
coverage.xml
htmlcov/
*.junit.xml
.tox/

# =============================================================================
# IDE and OS
# =============================================================================
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# =============================================================================
# Jupyter notebooks (outputs only — .ipynb source files ARE tracked)
# Strip cell outputs so diffs stay clean; outputs regenerate on re-run
# =============================================================================
.ipynb_checkpoints/

# =============================================================================
# Secrets — never commit credentials or secret scope values
# =============================================================================
*.env
.env.*
secrets.yml
credentials.json
service_account.json
